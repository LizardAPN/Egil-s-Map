{
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@imprint/types": ["packages/types/src"],
      "@imprint/api": ["packages/api/src"],
      "@imprint/ui": ["packages/ui/src"]
    }
  }
}
