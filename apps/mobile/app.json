{
  "expo": {
    "name": "Imprint",
    "slug": "imprint",
    "scheme": "imprint",
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsUseV11": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0f172a"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Imprint needs access to your photos so you can attach memories.",
          "cameraPermission": "Imprint needs camera access so you can capture memories."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Imprint uses your location to center the Memory Map and pin your memories.",
          "locationAlwaysAndWhenInUsePermission": "Imprint uses your location in the background to surface nearby Echoes from friends.",
          "isAndroidBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "infoPlist": {
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ],
      "package": "com.anonymous.imprint"
    }
  }
}
