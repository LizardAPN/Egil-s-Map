# Supabase — Dashboard → Settings → API (same project for URL + key)
#
# EXPO_PUBLIC_SUPABASE_ANON_KEY: copy the FULL key (no quotes, no spaces, one line).
#   • Publishable key: sb_publishable_… (recommended)
#   • Or legacy anon JWT: eyJhbGci… (tab "Legacy API keys")
# Never use sb_secret_… or service_role here.
#
# Phone / emulator CANNOT use 127.0.0.1 — that is the device itself.
# Local dev on a physical phone: use your PC LAN IP, e.g. http://192.168.1.13:54321
# Cloud (recommended for mobile): https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox — https://account.mapbox.com/access-tokens/
# Use your public token here (`pk...`). This is different from the secret
# downloads token needed for native Android/iOS builds.
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Supabase Storage buckets (must match buckets created in Supabase)
EXPO_PUBLIC_SUPABASE_MEMORY_BUCKET=memory-media
EXPO_PUBLIC_SUPABASE_CHAPTER_COVERS_BUCKET=chapter-covers

# Optional
EXPO_PUBLIC_APP_ENV=development
