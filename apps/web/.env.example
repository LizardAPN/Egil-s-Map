# Supabase local — copy from `npx supabase status` (use ANON_KEY JWT, not PUBLISHABLE_KEY)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-status

# Mapbox — https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_STYLE=mapbox://styles/mapbox/dark-v11

# Optional — show Google sign-in button (OAuth not configured locally)
# NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=true
