# Database
DATABASE_URL=postgresql+asyncpg://egilsmap:egilsmap_secret@localhost:5433/egilsmap

# Redis
REDIS_URL=redis://localhost:6379/0

# S3 (MinIO for dev, use AWS S3 in production)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=egilsmap-uploads
S3_REGION=us-east-1

# Auth
AUTH_SECRET=your-auth-secret-min-32-chars-change-in-production
JWT_SECRET=your-jwt-secret-min-32-chars-change-in-production
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=

# Backend
BACKEND_URL=http://localhost:8000

# Environment (development or production)
ENVIRONMENT=development
